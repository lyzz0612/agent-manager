# AgentOps Server 配置示例。复制为 .env 或通过容器环境变量传入。

# 部署侧单 Token：保护 Client HTTP API、Client WebSocket、Runner Channel。
AGENTOPS_TOKEN=replace-me-with-a-long-random-string

# HTTP 监听地址 / 端口
AGENTOPS_HOST=0.0.0.0
AGENTOPS_PORT=4000

# SQLite 数据库文件路径，建议使用持久化卷。
AGENTOPS_DB_PATH=./data/agentops.db

# 日志级别：debug / info / warn / error
AGENTOPS_LOG_LEVEL=info
