# Root development environment defaults for `pnpm dev` and Docker Compose dev-fast.
# Copy to `.env` for local overrides; never commit secrets.

# -------- Server --------
# Required by Server in production. For dev you may keep the default placeholder.
AGENTOPS_TOKEN=dev-token-not-for-production
AGENTOPS_HOST=0.0.0.0
AGENTOPS_PORT=4000
# SQLite path (absolute or repo-relative). Compose mounts ./.data/server.
AGENTOPS_DB_PATH=./.data/server/agentops.db
AGENTOPS_LOG_LEVEL=info

# -------- Client (Expo Web) --------
# Vite/Expo dev server port. Compose maps it to host.
EXPO_WEB_PORT=8081
# Server URL used by the web client to call the API + WebSocket.
AGENTOPS_SERVER_URL=http://localhost:4000

# -------- Runner --------
# Local-only state directory; keeps Runner from writing to $HOME during dev.
AGENTOPS_HOME=./.agentops-dev
# Force the runner into dev mode regardless of cwd.
AGENTOPS_DEV=1
# When the runner runs in Docker it talks to the Server via the compose network.
AGENTOPS_RUNNER_SERVER_URL=http://server:4000

# -------- Dev matrix selectors --------
# `local` (default) or `docker`. Consumed by ./scripts/dev.mjs.
SERVER_RUNTIME=local
CLIENT_RUNTIME=local
RUNNER_RUNTIME=docker
